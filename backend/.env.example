# DataSense backend configuration
# Copy this file to .env and adjust the values:  cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://datasense_user:datasense123@localhost:5432/datasense

# ── Security ─────────────────────────────────────────────────────────────────
# Session cookie signing (HMAC). If unset, an ephemeral key is generated and
# sessions reset on every server restart. Use a long random string.
SECRET_KEY=change-me-to-a-long-random-string

# Admin token for the cleanup endpoint (DELETE /api/jobs).
# The endpoint is disabled when this is unset.
ADMIN_TOKEN=change-me-to-a-different-random-string

# Set to true only when deployed behind a trusted reverse proxy —
# enables X-Forwarded-For for rate-limiting client identification.
TRUST_PROXY=false

# ── LLM Provider ─────────────────────────────────────────────────────────────
# One of: "ollama" (local, default), "openai", "groq"
LLM_PROVIDER=ollama

# Ollama (local) — must include /api/generate
OLLAMA_URL=http://localhost:11434/api/generate

# OpenAI (only if LLM_PROVIDER=openai)
#OPENAI_API_KEY=sk-...

# Groq (only if LLM_PROVIDER=groq)
#GROQ_API_KEY=gsk_...

# ── LLM Tuning ───────────────────────────────────────────────────────────────
LLM_TIMEOUT=60
LLM_BATCH_TIMEOUT=90
LLM_MAX_WORKERS=2
TOKEN_BUDGET=4096

# Default insight persona when the upload doesn't specify one:
# "general", "executive", "data_scientist", or "product_manager"
INSIGHT_PERSONA=general

# Set to false to skip AI calls and use rule-based insights only
USE_LLM=true

# ── Upload & Concurrency ─────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=200
MAX_CONCURRENT_JOBS=10
JOB_RETENTION_HOURS=48
TEMP_UPLOAD_DIR=temp_uploads

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60          # Global: max requests per window
RATE_LIMIT_WINDOW_S=60          # Global: window in seconds
RATE_LIMIT_STRICT_REQUESTS=10   # Strict (upload): max per window
RATE_LIMIT_STRICT_WINDOW_S=60   # Strict: window in seconds

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=datasense.log
LOG_MAX_BYTES=5242880           # 5 MB
LOG_BACKUP_COUNT=5
